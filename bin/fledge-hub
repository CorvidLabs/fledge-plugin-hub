#!/usr/bin/env bash
set -euo pipefail

# Resolve any symlink chain to find the real plugin dir. Required because
# fledge installs plugins by symlinking only the declared binary into a
# shared bin/ — sibling files live next to the symlink target, not the link.
SOURCE="${BASH_SOURCE[0]:-$0}"
while [ -L "$SOURCE" ]; do
  LINK_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$LINK_DIR/$SOURCE"
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

DIR="${FLEDGE_PLUGIN_DIR:-$(cd "$BIN_DIR/.." && pwd)}"
cd "$DIR"

PORT="${FLEDGE_HUB_PORT:-3800}"
export PORT

echo "Starting fledge hub on http://localhost:${PORT}"
exec bun run src/server.ts
